# ──────────────────────────────────────────────────────────────────────────────
# Boss Hiring Telegram Bot 环境变量配置文件模板
# ──────────────────────────────────────────────────────────────────────────────

# 1. Telegram Bot 配置
# ------------------------------------------------------------------------------
# 您的 Telegram Bot API Token，从 @BotFather 处获取（必填）
TELEGRAM_BOT_TOKEN=

# Bot 的公网可访问 URL，用于配置 Webhook（例如 https://your-bot.vercel.app）
BOT_PUBLIC_URL=https://boss-hiring.vercel.app

# Boss Hiring 官方网站链接
BOSS_HIRING_WEBSITE=https://boss-hiring.vercel.app/#company

# 内部通知群组/频道的 Telegram Chat ID，顾问在此群接收求职与招聘文件提醒
INTERNAL_TELEGRAM_CHAT_ID=

# 管理员的 Telegram User ID，最多配置 3 个，英文逗号分隔（如: 1234567,8901234）
# 这些用户在与 Bot 交互时能看到并操作“管理员控制台”
TG_ADMIN_ID=


# 2. Airtable 数据库集成配置
# ------------------------------------------------------------------------------
# Airtable 个人访问令牌 (Personal Access Token, PAT)（必填）
# 需要具备 data.records:read, data.records:write 权限（若要自动建表，还需 schema.bases:read, schema.bases:write 权限）
AIRTABLE_PAT=

# Airtable 基础数据库 ID (Base ID)，格式形如 appXXXXXXXXXXXXXX（必填）
# 必须先在 Airtable 网页上手动创建 Base，然后在此处填入其 ID
AIRTABLE_BASE_ID=


# 3. Gemini AI 引擎配置
# ------------------------------------------------------------------------------
# Google AI Studio 获取的 API 密钥，用于调用 Gemini 2.5/1.5 模型（必填）
GEMINI_API_KEY=

# 用于智能匹配与复杂决策的高阶模型，严格禁止降级（默认: gemini-1.5-pro）
GEMINI_PRO_MODEL=gemini-1.5-pro

# 用于摘要提取、标签化和轻量分析的快速模型（默认: gemini-1.5-flash）
GEMINI_FLASH_MODEL=gemini-1.5-flash


# 4. 安全防护与 Webhook
# ------------------------------------------------------------------------------
# 与 Google Apps Script 交互时的安全验证密钥（建议设置）
# 必须与 Google Sheets Apps Script 中配置的 `WEBHOOK_SECRET` 完全一致，用以防止接口被恶意调用
WEBHOOK_SECRET=
